<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>parquet_output</name>
    <description>Writes a small dataset to HDFS as a Parquet file through the hc:// VFS scheme (named cluster + shim).</description>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters>
      <parameter>
        <name>NAMED_CLUSTER</name>
        <default_value>it-cluster</default_value>
        <description>Named cluster used to resolve HDFS</description>
      </parameter>
      <parameter>
        <name>HDFS_PATH</name>
        <default_value>/it/formats/cars.parquet</default_value>
        <description>Absolute HDFS path of the output Parquet file</description>
      </parameter>
    </parameters>
    <log/>
    <maxdate>
      <connection/>
      <table/>
      <field/>
      <offset>0.0</offset>
      <maxdiff>0.0</maxdiff>
    </maxdate>
    <size_rowset>10000</size_rowset>
    <sleep_time_empty>50</sleep_time_empty>
    <sleep_time_full>50</sleep_time_full>
    <unique_connections>N</unique_connections>
    <feedback_shown>Y</feedback_shown>
    <feedback_size>50000</feedback_size>
    <using_thread_priorities>Y</using_thread_priorities>
    <shared_objects_file/>
    <capture_step_performance>N</capture_step_performance>
    <dependencies/>
    <partitionschemas/>
    <slaveservers/>
    <clusterschemas/>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
  </info>
  <notepads/>
  <order>
    <hop>
      <from>Data grid</from>
      <to>Parquet output</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Parquet output</from>
      <to>Write to log</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <step>
    <name>Data grid</name>
    <type>DataGrid</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <name>brand</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
      <field>
        <name>model</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <data>
      <line>
        <item>Toyota</item>
        <item>Corolla</item>
      </line>
      <line>
        <item>Honda</item>
        <item>Civic</item>
      </line>
      <line>
        <item>Ford</item>
        <item>Focus</item>
      </line>
    </data>
    <cluster_schema/>
    <remotesteps>
      <input/>
      <output/>
    </remotesteps>
    <GUI>
      <xloc>176</xloc>
      <yloc>112</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Parquet output</name>
    <type>ParquetOutput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <filename>hc://${NAMED_CLUSTER}${HDFS_PATH}</filename>
    <overrideOutput>Y</overrideOutput>
    <compression>UNCOMPRESSED</compression>
    <parquetVersion>Parquet 1.0</parquetVersion>
    <enableDictionary>N</enableDictionary>
    <dictPageSize>1024</dictPageSize>
    <rowGroupSize/>
    <dataPageSize/>
    <extension/>
    <dateInFilename>N</dateInFilename>
    <timeInFilename>N</timeInFilename>
    <dateTimeFormat/>
    <fields>
      <field>
        <path>brand</path>
        <name>brand</name>
        <type>String</type>
        <precision>0</precision>
        <scale>0</scale>
        <nullable>Y</nullable>
        <default/>
      </field>
      <field>
        <path>model</path>
        <name>model</name>
        <type>String</type>
        <precision>0</precision>
        <scale>0</scale>
        <nullable>Y</nullable>
        <default/>
      </field>
    </fields>
    <cluster_schema/>
    <remotesteps>
      <input/>
      <output/>
    </remotesteps>
    <GUI>
      <xloc>400</xloc>
      <yloc>112</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Write to log</name>
    <type>WriteToLog</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <loglevel>log_level_basic</loglevel>
    <displayHeader>Y</displayHeader>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <logmessage>bigdata-it-parquet-write-ok</logmessage>
    <fields>
      <field>
        <name>brand</name>
      </field>
    </fields>
    <cluster_schema/>
    <remotesteps>
      <input/>
      <output/>
    </remotesteps>
    <GUI>
      <xloc>624</xloc>
      <yloc>112</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step_error_handling/>
  <slave-step-copy-partition-distribution/>
  <slave_transformation>N</slave_transformation>
</transformation>
