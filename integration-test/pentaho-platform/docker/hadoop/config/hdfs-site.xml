<?xml version="1.0" encoding="UTF-8"?>
<!--
  HDFS site configuration for the single-node Hadoop integration-test container.
  Single-node cluster: replication factor 1, permissions disabled, fixed name/data dirs
  (so the container command can detect whether the namenode is already formatted), and
  hostname-based data node access so the PDI client (in another container) can reach it.
-->
<configuration>
  <property>
    <name>dfs.replication</name>
    <value>1</value>
  </property>
  <property>
    <name>dfs.permissions.enabled</name>
    <value>false</value>
  </property>
  <property>
    <name>dfs.namenode.name.dir</name>
    <value>file:///tmp/hdfs/name</value>
  </property>
  <property>
    <name>dfs.datanode.data.dir</name>
    <value>file:///tmp/hdfs/data</value>
  </property>
  <property>
    <name>dfs.namenode.rpc-address</name>
    <value>hadoop-hostname:9000</value>
  </property>
  <property>
    <name>dfs.namenode.rpc-bind-host</name>
    <value>0.0.0.0</value>
  </property>
  <property>
    <name>dfs.namenode.servicerpc-bind-host</name>
    <value>0.0.0.0</value>
  </property>
  <property>
    <name>dfs.namenode.http-bind-host</name>
    <value>0.0.0.0</value>
  </property>
  <property>
    <name>dfs.datanode.hostname</name>
    <value>hadoop-hostname</value>
  </property>
  <property>
    <name>dfs.client.use.datanode.hostname</name>
    <value>true</value>
  </property>
  <property>
    <name>dfs.datanode.use.datanode.hostname</name>
    <value>true</value>
  </property>
</configuration>
